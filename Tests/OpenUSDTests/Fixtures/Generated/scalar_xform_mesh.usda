    }

    def Xform "ScaleY"
    {
        double xformOp:scaleY = 3
        uniform token[] xformOpOrder = ["xformOp:scaleY"]

        def Mesh "TriangleScaleY"
        {
            point3f[] points = [(1, 1, 1), (2, 1, 1), (1, 2, 1)]
            int[] faceVertexCounts = [3]
            int[] faceVertexIndices = [0, 1, 2]
            uniform token subdivisionScheme = "none"
        }
    }

    def Xform "ScaleZ"
    {
        float xformOp:scaleZ = 4
        uniform token[] xformOpOrder = ["xformOp:scaleZ"]

        def Mesh "TriangleScaleZ"
        {
            point3f[] points = [(1, 1, 1), (2, 1, 1), (1, 2, 1)]
