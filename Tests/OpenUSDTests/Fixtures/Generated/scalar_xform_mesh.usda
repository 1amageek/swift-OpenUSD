#usda 1.0
(
    defaultPrim = "Root"
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "Root"
{
    def Xform "TranslateX"
    {
        double xformOp:translateX = 2
        uniform token[] xformOpOrder = ["xformOp:translateX"]

        def Mesh "TriangleTranslateX"
        {
            point3f[] points = [(1, 1, 1), (2, 1, 1), (1, 2, 1)]
            int[] faceVertexCounts = [3]
            int[] faceVertexIndices = [0, 1, 2]
            uniform token subdivisionScheme = "none"
        }
    }

    def Xform "TranslateY"
    {
        float xformOp:translateY = 3
        uniform token[] xformOpOrder = ["xformOp:translateY"]

